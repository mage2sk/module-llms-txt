<?xml version="1.0"?>
<!--
/**
 * Panth LLMs.txt — System configuration.
 *
 * Owns the `panth_llms_txt` section under the shared `panth` tab.
 * v1.3 layers on five new groups for the AI Indexing Engine
 * (Sitemap Engine, Weighting & Ranking, Use Cases, JSON Output,
 * Cron) on top of the existing General / Limits / Curated Products
 * / llms-full groups so admins see one coherent surface.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="panth_llms_txt" translate="label" sortOrder="85" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>LLMs.txt</label>
            <tab>panth</tab>
            <resource>Panth_LlmsTxt::config</resource>

            <group id="llms_txt" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable llms.txt</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When enabled, serves /llms.txt with a curated Markdown site map for LLM crawlers.</comment>
                </field>
                <field id="summary" translate="label comment" type="textarea" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Site Summary</label>
                    <comment><![CDATA[Short one-line summary for the llms.txt header. Leave blank to auto-generate from store metadata (product count, top categories, currency). Falls back to <code>design/head/default_description</code> when both are empty.]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="priority_urls" translate="label comment" type="textarea" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Priority URLs</label>
                    <comment><![CDATA[One URL per line. Format: <code>Label | /path</code> or just <code>/path</code> (label auto-inferred). Rendered under "## Priority URLs" — gives LLM crawlers an explicit hint about your most important pages. Example:<br/><code>Sale | /sale<br/>New Arrivals | /collections/new<br/>Size Guide | /size-guide</code>]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="collections_categories" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Collections (Category IDs)</label>
                    <comment><![CDATA[Comma-separated category IDs that represent curated landing pages (e.g. <em>New Arrivals</em>, <em>Sale</em>, <em>Eco-Friendly</em>). Rendered under "## Collections" — separate from the full category tree so LLMs understand these are promotional. Example: <code>12,18,22</code>.]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <group id="sitemap" translate="label" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Sitemap Engine</label>
                <comment><![CDATA[Pulls real sitemap data (loc / lastmod / priority) into the AI index. Supports plain <code>&lt;urlset&gt;</code> sitemaps and <code>&lt;sitemapindex&gt;</code> documents that nest one level.]]></comment>
                <field id="urls" translate="label comment" type="textarea" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Sitemap URLs</label>
                    <comment><![CDATA[One sitemap URL per line. Absolute (<code>https://example.com/sitemap_products.xml</code>) or relative (<code>/sitemap.xml</code>). Lines starting with <code>#</code> are treated as comments. Leave blank to use Magento's default <code>/sitemap.xml</code>.]]></comment>
                </field>
                <field id="auto" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Auto-detect Default Sitemap</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When the URL list above is empty, fall back to <code>{baseUrl}sitemap.xml</code>.</comment>
                </field>
                <field id="render_section" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Render "Sitemap Highlights" Section</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When on, the highest-scored sitemap rows are listed under their own section in /llms.txt and /llms-full.txt.</comment>
                </field>
                <field id="max_rendered" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Rendered Sitemap Rows</label>
                    <validate>validate-digits</validate>
                    <comment>Hard cap on rows rendered under "## Sitemap Highlights". Default: 50.</comment>
                    <depends>
                        <field id="render_section">1</field>
                    </depends>
                </field>
                <field id="max_entries" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Parsed Sitemap Entries</label>
                    <validate>validate-digits</validate>
                    <comment>Upper bound on entries the parser will load into memory across all configured sitemaps. Default: 5000.</comment>
                </field>
                <field id="timeout" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Per-request Timeout (seconds)</label>
                    <validate>validate-digits</validate>
                    <comment>Per-sitemap connect + read timeout. Default: 8.</comment>
                </field>
                <field id="ttl" translate="label comment" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Sitemap Cache TTL (seconds)</label>
                    <validate>validate-digits</validate>
                    <comment>How long parsed sitemap data stays cached. Default: 3600 (1 hour).</comment>
                </field>
            </group>

            <group id="weighting" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Weighting &amp; Ranking</label>
                <comment><![CDATA[Combines sitemap priority, admin pinned URLs and built-in business heuristics into a single 0.0 – 1.0 score per entry. Entries below the cut-off are dropped.]]></comment>
                <field id="type_weights" translate="label comment" type="textarea" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Type Weights</label>
                    <comment><![CDATA[<code>code=weight</code> per line, where code is one of <code>homepage</code>, <code>category</code>, <code>collection</code>, <code>product</code>, <code>cms</code>, <code>sitemap</code>, <code>external</code>. Example:<br/><code>category=0.75<br/>product=0.55</code><br/>Defaults bias toward category and CMS pages.]]></comment>
                </field>
                <field id="pinned_urls" translate="label comment" type="textarea" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Pinned URLs</label>
                    <comment><![CDATA[<code>url_or_prefix=score</code> per line. Pinned values override every other signal. Wildcards: <code>/sale/*=1.0</code> pins the entire path tree.]]></comment>
                </field>
                <field id="min_score" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Minimum Score</label>
                    <comment>Entries scoring below this are dropped. Default: 0.20.</comment>
                </field>
                <field id="max_entries_per_section" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Entries Per Section</label>
                    <validate>validate-digits</validate>
                    <comment>Per-section hard cap applied after sorting. Default: 200.</comment>
                </field>
            </group>

            <group id="limits" translate="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Content Limits</label>
                <field id="max_category_depth" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Category Tree Depth</label>
                    <validate>validate-digits validate-digits-range digits-range-1-5</validate>
                    <config_path>panth_llms_txt/llms_txt/max_category_depth</config_path>
                    <comment>How many levels of the category tree to include (1–5). Default: 3.</comment>
                </field>
                <field id="max_cms" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max CMS Pages</label>
                    <validate>validate-digits</validate>
                    <config_path>panth_llms_txt/llms_txt/max_cms</config_path>
                    <comment>Max CMS pages to include under "## Key Pages". Default: 10.</comment>
                </field>
                <field id="exclude_cms" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Exclude CMS Identifiers</label>
                    <config_path>panth_llms_txt/llms_txt/exclude_cms</config_path>
                    <comment><![CDATA[Comma-separated identifiers to omit. Defaults <code>no-route</code>, <code>privacy-policy-cookie-restriction-mode</code>, <code>enable-cookies</code> are always excluded — this field adds to that list.]]></comment>
                </field>
            </group>

            <group id="products" translate="label" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Curated Products</label>
                <field id="featured_attribute" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Featured Attribute Code</label>
                    <config_path>panth_llms_txt/llms_txt/featured_attribute</config_path>
                    <comment><![CDATA[Yes/No EAV attribute code used to mark featured products. Default: <code>is_featured</code>. If the attribute doesn't exist the section is silently skipped.]]></comment>
                </field>
                <field id="max_featured" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Featured Products</label>
                    <validate>validate-digits</validate>
                    <config_path>panth_llms_txt/llms_txt/max_featured</config_path>
                    <comment>Max items under "## Featured Products". Default: 6. Set to 0 to disable.</comment>
                </field>
                <field id="show_bestsellers" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show Best Sellers</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>panth_llms_txt/llms_txt/show_bestsellers</config_path>
                    <comment>Render a "## Best Sellers" block from Magento's bestseller aggregate (top ordered qty). Requires the bestseller indexer.</comment>
                </field>
                <field id="max_bestsellers" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Best Sellers</label>
                    <validate>validate-digits</validate>
                    <config_path>panth_llms_txt/llms_txt/max_bestsellers</config_path>
                    <comment>Max items under "## Best Sellers". Default: 10.</comment>
                    <depends>
                        <field id="show_bestsellers">1</field>
                    </depends>
                </field>
                <field id="show_recent" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show Recent Arrivals</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>panth_llms_txt/llms_txt/show_recent</config_path>
                    <comment>Render a "## Recent Arrivals" block sorted by created_at.</comment>
                </field>
                <field id="max_recent" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Recent Arrivals</label>
                    <validate>validate-digits</validate>
                    <config_path>panth_llms_txt/llms_txt/max_recent</config_path>
                    <comment>Max items under "## Recent Arrivals". Default: 10.</comment>
                    <depends>
                        <field id="show_recent">1</field>
                    </depends>
                </field>
                <field id="include_short_description" translate="label comment" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include Short Descriptions</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>panth_llms_txt/llms_txt/include_short_description</config_path>
                    <comment>When on, each curated product gets a one-line description beneath its link (from short_description → meta_description → first sentence of description → auto-generated "Name — Category").</comment>
                </field>
            </group>

            <group id="product_types" translate="label" sortOrder="45" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Product Types Section</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Render "Product Types"</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When on, /llms.txt and /llms.json include a metadata block with counts per Magento product type (simple, configurable, bundle, …).</comment>
                </field>
            </group>

            <group id="use_cases" translate="label" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Use Cases (Shopper Intent)</label>
                <field id="buckets" translate="label comment" type="textarea" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Use-case Buckets</label>
                    <comment><![CDATA[<code>Label | category_id_csv [| summary]</code> per line. Maps a shopper intent to one or more category IDs. Rendered under "## Use Cases". Examples:<br/><code>Daily Wear | 12,18,33<br/>Bridal | 41 | Hand-embroidered bridal lehengas and saris<br/>Festive | 14,27</code>]]></comment>
                </field>
            </group>

            <group id="full" translate="label" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>llms-full.txt (Expanded)</label>
                <field id="generate_full_llms" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable llms-full.txt</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>panth_llms_txt/llms_txt/generate_full_llms</config_path>
                    <comment>Serves /llms-full.txt with inline shipping / returns / FAQ / about-us policy bodies in addition to the llms.txt content.</comment>
                </field>
                <field id="shipping_page" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Shipping Policy CMS Identifier</label>
                    <config_path>panth_llms_txt/llms_txt/shipping_page</config_path>
                    <comment>Example: <code>shipping-policy</code>.</comment>
                    <depends>
                        <field id="generate_full_llms">1</field>
                    </depends>
                </field>
                <field id="returns_page" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Returns Policy CMS Identifier</label>
                    <config_path>panth_llms_txt/llms_txt/returns_page</config_path>
                    <comment>Example: <code>returns-policy</code>.</comment>
                    <depends>
                        <field id="generate_full_llms">1</field>
                    </depends>
                </field>
                <field id="about_page" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>About Us CMS Identifier</label>
                    <config_path>panth_llms_txt/llms_txt/about_page</config_path>
                    <comment>Example: <code>about-us</code>.</comment>
                    <depends>
                        <field id="generate_full_llms">1</field>
                    </depends>
                </field>
                <field id="faq_page" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>FAQ CMS Identifier</label>
                    <config_path>panth_llms_txt/llms_txt/faq_page</config_path>
                    <comment>Example: <code>faq</code>.</comment>
                    <depends>
                        <field id="generate_full_llms">1</field>
                    </depends>
                </field>
            </group>

            <group id="json" translate="label" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>llms.json (Machine-readable)</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable /llms.json</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Serves a structured JSON document at /llms.json containing the same sections in a stable, machine-readable shape (schema: <code>panth.llms_txt/v1</code>).</comment>
                </field>
            </group>

            <group id="cron" translate="label" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Cache Warm-up</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Pre-warm Caches via Cron</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When on, the nightly cron at 02:30 regenerates llms.txt / llms-full.txt / llms.json and refreshes the parsed sitemap cache for every enabled store.</comment>
                </field>
            </group>

            <group id="optional" translate="label" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Optional Integrations</label>
                <comment><![CDATA[Surface entities from sister Panth modules in /llms.txt and /llms.json. Each integration is conditional on the source module being installed — if the module is missing the toggle has no effect (the section silently renders nothing).]]></comment>
                <field id="include_testimonials" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include Testimonials</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Adds approved testimonial categories and individual testimonial pages from Panth_Testimonials.</comment>
                </field>
                <field id="include_faqs" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include FAQs</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Adds FAQ categories and individual FAQ items (with url_key) from Panth_Faq.</comment>
                </field>
                <field id="include_dynamic_forms" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include Dynamic Forms</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Adds page-type dynamic forms from Panth_DynamicForms (skips widget-only forms).</comment>
                </field>
            </group>
        </section>
    </system>
</config>
